#!/bin/sh
# dsRadiomics post-install configuration script
# Runs automatically during R CMD INSTALL on Unix systems.
#
# Creates Python virtual environments for radiomics extraction and
# segmentation frameworks. Only installs frameworks (lightweight).
# Model weights are NOT downloaded here -- use admin commands for that.
#
# Self-contained: if neither Python nor uv are present, downloads uv
# (a single static binary) and uses it to install Python.

VENV_ROOT="${DSRADIOMICS_VENV_ROOT:-/var/lib/dsradiomics/venvs}"
LOG_PREFIX="[dsRadiomics configure]"

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

log_info() { echo "${LOG_PREFIX} $*"; }
log_warn() { echo "${LOG_PREFIX} WARNING: $*" >&2; }

check_import() { "$1" -c "import $2" 2>/dev/null; }

# ---------------------------------------------------------------------------
# Bootstrap: ensure uv + Python are available
# ---------------------------------------------------------------------------

ensure_uv() {
  UV="$(command -v uv 2>/dev/null || true)"
  if [ -n "${UV}" ] && [ -x "${UV}" ]; then return 0; fi

  for _p in "${HOME}/.local/bin/uv" "${HOME}/.cargo/bin/uv" "/usr/local/bin/uv"; do
    if [ -x "${_p}" ]; then UV="${_p}"; return 0; fi
  done

  log_info "Downloading uv (Python package manager)..."

  if command -v curl >/dev/null 2>&1; then
    _DL="curl -LsSf"
  elif command -v wget >/dev/null 2>&1; then
    _DL="wget -qO-"
  else
    if command -v apt-get >/dev/null 2>&1; then
      apt-get update -qq 2>/dev/null && apt-get install -y -qq curl 2>/dev/null
      _DL="curl -LsSf"
    elif command -v apk >/dev/null 2>&1; then
      apk add --no-cache curl 2>/dev/null
      _DL="curl -LsSf"
    else
      log_warn "No curl/wget available. Cannot download uv."
      return 1
    fi
  fi

  ${_DL} https://astral.sh/uv/install.sh 2>/dev/null | sh 2>/dev/null
  UV="${HOME}/.local/bin/uv"
  if [ ! -x "${UV}" ]; then UV="$(command -v uv 2>/dev/null || true)"; fi
  if [ -n "${UV}" ] && [ -x "${UV}" ]; then
    log_info "uv installed: $(${UV} --version)"
    return 0
  fi
  log_warn "Failed to install uv."
  return 1
}

ensure_python() {
  # uv provides Python -- no system Python needed
  if [ -z "${UV}" ] || [ ! -x "${UV}" ]; then
    log_warn "No uv available. Cannot provision Python."
    return 1
  fi

  PYTHON="$("${UV}" python find 3.11 2>/dev/null || true)"
  if [ -n "${PYTHON}" ] && [ -x "${PYTHON}" ]; then
    log_info "Python: ${PYTHON} ($("${PYTHON}" --version 2>&1 | head -1))"
    return 0
  fi

  log_info "Installing Python 3.11 via uv..."
  "${UV}" python install 3.11 --quiet 2>&1 || true

  PYTHON="$("${UV}" python find 3.11 2>/dev/null || true)"
  if [ -n "${PYTHON}" ] && [ -x "${PYTHON}" ]; then
    log_info "Python installed: ${PYTHON} ($("${PYTHON}" --version 2>&1 | head -1))"
    return 0
  fi

  log_warn "Failed to install Python via uv."
  return 1
}

# --- Run bootstrap ---

ensure_uv || {
  log_warn "uv not available. Cannot proceed."
  log_warn "Install uv: https://docs.astral.sh/uv/"
  exit 0
}

ensure_python || {
  log_warn "No Python available. Skipping environment setup."
  exit 0
}

USE_UV=true

mkdir -p "${VENV_ROOT}" 2>/dev/null || {
  log_warn "Cannot create ${VENV_ROOT}. Skipping."
  exit 0
}
log_info "Venv root: ${VENV_ROOT}"

# ---------------------------------------------------------------------------
# Installer functions
# ---------------------------------------------------------------------------

create_venv() {
  local name="$1"
  local venv_path="${VENV_ROOT}/${name}"
  if [ -d "${venv_path}" ] && [ -f "${venv_path}/.dsradiomics_ready" ]; then
    log_info "  ${name}: already provisioned."
    return 0
  fi
  log_info "  ${name}: creating venv..."
  rm -rf "${venv_path}"
  if [ "${USE_UV}" = true ]; then
    "${UV}" venv --python "${PYTHON}" --seed "${venv_path}" >/dev/null 2>&1
  else
    "${PYTHON}" -m venv --system-site-packages "${venv_path}"
  fi
}

install_deps() {
  local name="$1"; shift
  local venv_path="${VENV_ROOT}/${name}"
  local venv_python="${venv_path}/bin/python"
  log_info "  ${name}: installing $*"
  if [ "${USE_UV}" = true ]; then
    "${UV}" pip install --python "${venv_python}" --quiet "$@" 2>&1 | tail -5
  else
    "${venv_path}/bin/pip" install --quiet --no-cache-dir "$@" 2>&1 | tail -5
  fi
}

mark_ready() {
  echo "$2" > "${VENV_ROOT}/$1/.dsradiomics_ready"
}

provision_framework() {
  local name="$1"; local check_module="$2"; shift 2; local deps="$*"
  local venv_path="${VENV_ROOT}/${name}"

  if [ -f "${venv_path}/.dsradiomics_ready" ]; then
    if check_import "${venv_path}/bin/python" "${check_module}" 2>/dev/null; then
      log_info "  ${name}: OK (cached)"
      return 0
    fi
    log_info "  ${name}: cached but unhealthy, rebuilding..."
  fi

  if check_import "${PYTHON}" "${check_module}" 2>/dev/null; then
    log_info "  ${name}: system Python has ${check_module}, skipping venv."
    return 0
  fi

  create_venv "${name}" || { log_warn "  ${name}: venv failed."; return 0; }

  # shellcheck disable=SC2086
  install_deps "${name}" "numpy>=1.21.0" "pandas>=1.3.0" ${deps} || {
    log_warn "  ${name}: install failed."; rm -rf "${venv_path}"; return 0
  }

  if check_import "${venv_path}/bin/python" "${check_module}"; then
    dep_hash=$(echo "${deps}" | sha256sum 2>/dev/null | cut -d' ' -f1 || echo "unknown")
    mark_ready "${name}" "${dep_hash}"
    log_info "  ${name}: ready."
  else
    log_warn "  ${name}: import ${check_module} failed."; rm -rf "${venv_path}"
  fi
}

# ---------------------------------------------------------------------------
# Provision environments
# ---------------------------------------------------------------------------

log_info "Provisioning Python environments for radiomics/segmentation..."
log_info "(Installs frameworks only. Model weights installed separately by admin.)"
echo ""

# PyRadiomics (requires C compilation)
log_info "  radiomics: preparing build environment..."
if command -v apt-get >/dev/null 2>&1; then
  apt-get update -qq 2>/dev/null && apt-get install -y -qq build-essential python3-dev git 2>/dev/null || true
fi

RADIOMICS_VENV="${VENV_ROOT}/radiomics"
if [ -f "${RADIOMICS_VENV}/.dsradiomics_ready" ] && check_import "${RADIOMICS_VENV}/bin/python" "radiomics" 2>/dev/null; then
  log_info "  radiomics: OK (cached)"
else
  if check_import "${PYTHON}" "radiomics" 2>/dev/null; then
    log_info "  radiomics: system Python has radiomics, skipping venv."
  else
    create_venv "radiomics" || { log_warn "  radiomics: venv failed."; }
    if [ -d "${RADIOMICS_VENV}" ]; then
      install_deps "radiomics" "numpy" "setuptools" "setuptools-scm" "wheel" "scikit-build-core" "cmake"
      log_info "  radiomics: installing pyradiomics from source..."
      if [ "${USE_UV}" = true ]; then
        "${UV}" pip install --python "${RADIOMICS_VENV}/bin/python" --no-build-isolation \
          "pyradiomics @ git+https://github.com/AIM-Harvard/pyradiomics.git" \
          SimpleITK pandas pyyaml 2>&1 | tail -3
      else
        "${RADIOMICS_VENV}/bin/pip" install --no-build-isolation \
          "pyradiomics @ git+https://github.com/AIM-Harvard/pyradiomics.git" \
          SimpleITK pandas pyyaml 2>&1 | tail -3
      fi
      if check_import "${RADIOMICS_VENV}/bin/python" "radiomics" 2>/dev/null; then
        echo "ready" > "${RADIOMICS_VENV}/.dsradiomics_ready"
        log_info "  radiomics: ready."
      else
        log_warn "  radiomics: install failed."; rm -rf "${RADIOMICS_VENV}"
      fi
    fi
  fi
fi

provision_framework "seg_totalseg" "totalsegmentator" \
  "TotalSegmentator>=2.0.0" "torch>=2.0.0" "SimpleITK>=2.0.0" "nibabel>=4.0.0"

provision_framework "seg_lungmask" "lungmask" \
  "lungmask>=0.2.0" "torch>=2.0.0" "SimpleITK>=2.0.0" "nibabel>=4.0.0"

provision_framework "seg_nnunetv2" "nnunetv2" \
  "nnunetv2>=2.0.0" "torch>=2.0.0" "SimpleITK>=2.0.0" "nibabel>=4.0.0"

provision_framework "seg_monai" "monai" \
  "monai>=1.3.0" "torch>=2.0.0" "SimpleITK>=2.0.0" "nibabel>=4.0.0" "pyyaml>=5.0"

echo ""
log_info "Python environment setup complete."
log_info "Venvs in: ${VENV_ROOT}"
log_info ""
log_info "NOTE: Model weights are NOT installed automatically."
log_info "Use admin commands to install models:"
log_info "  dsRadiomics::register_segmentation_model(...)"

for fw in radiomics seg_totalseg seg_nnunetv2 seg_monai; do
  venv="${VENV_ROOT}/${fw}"
  if [ -f "${venv}/.dsradiomics_ready" ]; then
    size=$(du -sh "${venv}" 2>/dev/null | cut -f1)
    log_info "  ${fw}: ${size}"
  fi
done

exit 0
